# Normalize line endings to avoid CRLF/LF churn across platforms.
* text=auto eol=lf

# Explicit text types
*.java   text eol=lf
*.xml    text eol=lf
*.yaml   text eol=lf
*.yml    text eol=lf
*.properties text eol=lf
*.md     text eol=lf
*.js     text eol=lf

# Binary artifacts
*.jar    binary
*.class  binary
*.png    binary
